# Copy this file to `.env` and fill in real values for local development.
# Railway projects supply these via the dashboard (Service → Variables).

# Public site URL used for canonical links and OG images.
PUBLIC_SITE_URL="https://hubaajto.hu"

# Where /api/lead drops its submissions. Defaults to info@szerx.hu when unset.
LEAD_DESTINATION_EMAIL="info@szerx.hu"

# Optional — Resend API key for transactional email delivery.
# When unset the lead endpoint logs to stdout only (see TODO in src/pages/api/lead.ts).
# RESEND_API_KEY=""

# Optional — port override. Railway sets this automatically; locally defaults to 8080.
# PORT="8080"
