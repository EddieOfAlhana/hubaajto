---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import TrustStrip from "../components/TrustStrip.astro";
import Stat from "../components/Stat.astro";
import LockBrandWall from "../components/LockBrandWall.astro";
import ContactCTA from "../components/ContactCTA.astro";
import { SITE, CONTACT } from "../data/site";

const yearsActive = new Date().getFullYear() - SITE.founded;

const milestones = [
  {
    year: "2003",
    title: "Szer-X3 Kft. alapítás",
    body: "A Szer-X3 Kereskedelmi és Szolgáltató Kft. alapítása Kistarcsán. Az első cél egyszerű: prémium minőségű, mégis elérhető árú acél biztonsági ajtót gyártani — pontos szállítási határidőkkel.",
  },
  {
    year: "2005",
    title: "ACTUAL Fenster forgalmazás",
    body: "Megkezdjük az osztrák ACTUAL Fenster ablakok magyarországi forgalmazását. A PVC- és fa-ablakok mellé a sorrendiség logikus: aki ajtót cserél, az gyakran ablakot is.",
  },
  {
    year: "2009",
    title: "MABISZ-minősítés",
    body: "A Huba ajtó terméknév MABISZ-tanúsítványt kap. A magyar biztosítók ettől a ponttól fogadják el a kivitelünket a lakásbiztosítási alapfeltétel teljesítéseként.",
  },
  {
    year: "2014",
    title: "Stílus / korhű termékvonal",
    body: "Az első budapesti polgári lakásban végzett korhű, kazettás rekonstrukciós munkáink után létrejön a stílus / műemléki termékvonal. Ez azóta a műhely megkülönböztető képessége.",
  },
  {
    year: "2018",
    title: "Engedélyezési csomag",
    body: "Az első teljes körű, kulcsrakész műemléki engedélyezési munka — építész tervezővel és műemléki szakértői névjegyzékbe vett partnerrel együttműködve. Ettől a ponttól az ügyfél egy számlát kap.",
  },
  {
    year: "2024",
    title: "Második generáció",
    body: "A családi vállalkozás második generációja átveszi a műhely napi vezetését. Az alapítók a műszaki minőségellenőrzésnél maradnak — az új generáció hozza a digitális rendelési felületet és a modern kínálat bővítését.",
  },
  {
    year: "2026",
    title: "Jelenleg",
    body: `${yearsActive}+ év dokumentált beépítés, három generáció ugyanazon a címen: 2143 Kistarcsa, Nagytarcsai út 6. Műemléki belvárostól a budai agglomerációig.`,
  },
];

const principles = [
  {
    name: "Saját gyártás",
    body: "Egyetlen ajtót sem rendelünk be importon keresztül. A tok hegesztésétől a kilincs felszereléséig minden lépés a Kistarcsai műhelyben történik — így az is, hogy 10 év múlva is rendelhető a pótalkatrész.",
  },
  {
    name: "Számok, nem szuperlatívuszok",
    body: "Nem mondjuk, hogy „a legjobb biztonsági ajtó”. Helyette: MABISZ 2009 óta, 15 év szerkezeti garancia, 9+ záródási pont, 5 perc RC3 ellenállás. Tények, nem jelzők.",
  },
  {
    name: "Méretre szabva",
    body: "Sem panel-lakásra, sem polgári lakásra, sem új építésű családi házra nem létezik „univerzális méret”. Minden ajtót egyedileg gyártunk a felmért nyíláshoz.",
  },
  {
    name: "Felmérés ingyen, nyomás nélkül",
    body: "A helyszíni felmérés ingyenes, és semmilyen vásárlási kötelezettséggel nem jár. A felmérőnk anyagmintákat hoz, de nem hoz „csak ma érvényes ajánlatot”. Amit kínálunk, azt időnyomás nélkül kínáljuk.",
  },
  {
    name: "Hosszú garancia, hosszú szervizháttér",
    body: "15 év szerkezeti garancia — a piac leghosszabb vállalása. De a számokon túl: a műhely 22+ éve azon a címen működik, ahol a beépítés napján is volt. Egy számlát megtartani érdemes.",
  },
  {
    name: "Engedélyt is intézünk",
    body: "A műemléki és helyi védettségi környezetben a 4–6 hónapos engedélyezési folyamatot a Huba intézi — építész tervezővel és műemléki szakértővel együttműködve. Ön egy számlát kap, egy projektvezetőt, egy felelőst.",
  },
];
---
<BaseLayout
  title="Rólunk — Szer-X3 Kft., a Huba ajtó műhely"
  description={`Három generáció, ${yearsActive}+ év Kistarcsán. A Szer-X3 Kft. 2003 óta gyárt biztonsági ajtót — MABISZ-minősítés 2009-től, korhű / műemléki termékvonal 2014-től, ACTUAL Fenster ablakcsomag 2005-től.`}
>
  <Hero
    eyebrow={`Saját gyártás · ${SITE.founded} óta · Kistarcsa`}
    heading={`Egy műhely, három<br/>generáció — <em>22+ év</em><br/>ugyanazon a címen.`}
    lead={`A Szer-X3 Kft. családi vállalkozás Kistarcsán, ${CONTACT.address.postal} ${CONTACT.address.street} címen. ${SITE.founded} óta gyártunk biztonsági ajtót — MABISZ-minősítéssel ${SITE.mabiszSince}-től, korhű kivitellel a budapesti polgári lakásoktól az agglomeráció új építésű családi házaiig.`}
    pillars={[
      `${yearsActive}+ év dokumentált beépítés`,
      "3 generáció · 1 cím",
      `MABISZ ${SITE.mabiszSince}-től`,
      "Stílus + modern modellek",
      "ACTUAL Fenster ablakforgalmazás",
    ]}
    image="/assets/photos/hero/workshop.jpg"
    imageAlt="A Huba ajtó kistarcsai műhelyének belseje, hegesztőmester munka közben"
    imageCaption="2143 Kistarcsa, Nagytarcsai út 6."
    primaryCta={{ label: "Ingyenes felmérés", href: "/felmeres" }}
    secondaryCta={{ label: "Referenciák megtekintése", href: "/referenciak" }}
  />

  <div id="below"></div>
  <TrustStrip />

  <Section
    tone="paper"
    eyebrow="Számokban"
    heading="A műhely életében négy szám számít."
  >
    <div class="stats-grid">
      <Stat value={`${yearsActive}+`} label="év dokumentált beépítés" sub={`${SITE.founded} óta`} />
      <Stat value="3" label="generáció" sub="ugyanazon a Kistarcsai címen" />
      <Stat value="50+" label="fa és mart mintázat" sub="alapáron választható" />
      <Stat value={`${SITE.warrantyYears}`} label="év szerkezeti garancia" sub="a piac leghosszabb vállalása" />
    </div>
  </Section>

  <Section
    tone="cream"
    eyebrow="A történet"
    heading="2003-ban indult — egyetlen céllal."
    lead="A magyar piacon 2003-ban két szélsőség uralkodott: az olcsó importáru, ami egy év alatt rozsdásodni kezdett, és a luxus importajtók, amik 2 millió forint felett kezdődtek. A kettő között egy magyar manufaktúra hiányzott. Ezt a hézagot zárta be a Szer-X3 Kft."
  >
    <div class="story-grid">
      <div class="story-text reveal">
        <p>
          Az alapítók — egy hegesztőmester és egy lakatos — a Kistarcsai műhelyt 2003 nyarán indították el. Az első év három alapelvet rögzített, ami azóta sem változott: <strong>saját gyártás, méretre szabva, fix szállítási határidővel</strong>.
        </p>
        <p>
          2005-ben a műhely portfólióját egészítettük ki az osztrák <strong>ACTUAL Fenster</strong> ablakok forgalmazásával. A logika egyszerű: aki bejárati ajtót cserél, az gyakran ablakot is — és a két termék közös felmérése, közös beépítése Önnek pénzt, nekünk pedig hatékonyságot ad.
        </p>
        <p>
          2009 volt a következő mérföldkő: a <strong>MABISZ-tanúsítvány</strong> megszerzése. Innentől kezdve a magyar biztosítók a Huba ajtót elfogadták a lakásbiztosítási alapfeltétel teljesítéséhez. A „Huba ajtó” terméknév is ekkor lett a Szer-X3 Kft. saját, fogyasztói brandje.
        </p>
        <p>
          A műhely megkülönböztető képessége — <strong>a korhű, stílusbiztonsági ajtó</strong> — 2014 körül kristályosodott ki, az első budapesti polgári lakásban végzett kazettás rekonstrukció után. Egyetlen más magyar manufaktúra sem dolgozik ebben a regiszterben; a versenytársak vagy modern modelleket gyártanak, vagy bútorasztalos munkát — biztonsági szint nélkül. Mi mindkettőt ugyanazon a szerkezeti magon.
        </p>
        <p>
          2018-ra a műhely bevezette az <strong>engedélyezési csomagot</strong>: a budapesti műemléki ajtócsere 4–6 hónapos, három hatóságot érintő folyamatát mi intézzük — építész tervezővel és műemléki szakértői névjegyzékbe vett partnerrel közösen. Ön egyetlen számlát, egyetlen projektvezetőt, egyetlen felelőst kap.
        </p>
        <p>
          2024-ben a családi vállalkozás <strong>második generációja</strong> vette át a műhely napi vezetését. Az alapítók a műszaki minőségellenőrzésnél maradtak. Az új generáció hozta a digitális ajtótervezőt, az aktualizált weboldalt, és a modern modellek bővítését az agglomeráció keleti és budai íve felé.
        </p>
        <p>
          2026-ban jelenleg <strong>{yearsActive}+ év dokumentált beépítéssel</strong> dolgozunk — három generációval ugyanazon a Kistarcsai címen, ahonnan az első ajtó is kifutott. Egy 22+ éves munkahely garanciaszerződése többet ér, mint egy 2 éves cégé.
        </p>
      </div>

      <aside class="story-aside reveal">
        <p class="aside-eyebrow">Mérföldkövek</p>
        <ol class="milestones">
          {milestones.map(m => (
            <li class="milestone">
              <p class="milestone-year">{m.year}</p>
              <h3 class="milestone-title">{m.title}</h3>
              <p class="milestone-body">{m.body}</p>
            </li>
          ))}
        </ol>
      </aside>
    </div>
  </Section>

  <Section
    tone="paper"
    eyebrow="Alapelvek"
    heading="Hat dolog, amit nem változtatunk."
    lead="A piacon sok minden változik — alapanyagár, zárgyártói portfólió, építőipari konjunktúra. Ezt a hatot nem mozgatjuk."
  >
    <ul class="principles stagger">
      {principles.map(p => (
        <li class="principle">
          <h3 class="principle-name">{p.name}</h3>
          <p class="principle-body">{p.body}</p>
        </li>
      ))}
    </ul>
  </Section>

  <Section
    tone="cream"
    eyebrow="A műhely"
    heading="2143 Kistarcsa, Nagytarcsai út 6."
    lead="Az első ajtó is innen ment ki. A legutóbbi ma. A műhelybe vásárlókat időpontra fogadunk — előzetes egyeztetéssel a teljes gyártási folyamatot bemutatjuk."
  >
    <div class="workshop-grid">
      <figure class="workshop-figure reveal">
        <img src="/assets/photos/hero/workshop.jpg" alt="A Huba ajtó kistarcsai műhelye — hegesztőberendezés és kész biztonsági ajtó" loading="lazy" />
      </figure>
      <div class="workshop-text reveal">
        <p>
          A Kistarcsai műhely Pest megye keleti ívén, Budapesttől 18 km-re fekszik. Innen indul a 30 perces felmérési kör Budapestre, és innen indul az 1-órás körzet az agglomeráció keleti ívére (Mogyoród, Csömör, Veresegyház, Gödöllő, Fót) és budai agglomerációba (Telki, Budakeszi).
        </p>
        <p>
          A műhelyben hegesztőberendezés, lemezvágó, festőkamra, mintázat-marógép és az utolsó ellenőrzési pad működik. Minden ajtó <strong>kétszeres minőségellenőrzésen</strong> esik át — az alapítói generáció és a műszaki vezető is aláírja a beépítés előtt.
        </p>
        <p>
          Címünk: <strong>2143 Kistarcsa, Nagytarcsai út 6.</strong> · Nyitva tartás: {CONTACT.hours.weekday} · {CONTACT.hours.saturday}.
        </p>
      </div>
    </div>
    <LockBrandWall />
  </Section>

  <ContactCTA
    heading="Jöjjön be a műhelybe — vagy hívja a felmérőnket"
    lead="Időpontot kérünk a műhelyi látogatáshoz — előzetes egyeztetés után a teljes gyártási folyamatot bemutatjuk. Helyszíni felmérésre Budapest és Pest megye területén utazunk ki, ingyenesen."
  />
</BaseLayout>

<style>
  .stats-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem;
  }
  @media (min-width: 800px) { .stats-grid { grid-template-columns: repeat(4, 1fr); } }

  .story-grid {
    display: grid; grid-template-columns: 1fr; gap: 3rem;
  }
  @media (min-width: 1024px) { .story-grid { grid-template-columns: 1.4fr 1fr; gap: 4rem; align-items: start; } }

  .story-text p {
    font-size: 1.02rem; line-height: 1.7; color: var(--color-charcoal);
    max-width: 60ch; margin-bottom: 1.25rem;
  }
  .story-text strong { color: var(--color-ink); font-weight: 500; }

  .story-aside { background: var(--color-paper); padding: 2rem 1.75rem; }
  .aside-eyebrow {
    font-size: 0.72rem; letter-spacing: var(--tracking-wide); text-transform: uppercase;
    color: var(--color-brass); margin-bottom: 1.5rem;
  }

  .milestones { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1.75rem; position: relative; }
  .milestones::before {
    content: ""; position: absolute; left: 0.4rem; top: 0.5rem; bottom: 0.5rem;
    width: 1px; background: rgba(14,15,17,0.12);
  }
  .milestone { padding-left: 1.5rem; position: relative; }
  .milestone::before {
    content: ""; position: absolute; left: 0; top: 0.5rem; width: 0.85rem; height: 0.85rem;
    background: var(--color-brass); border-radius: 50%;
  }
  .milestone-year {
    font-family: var(--font-serif); font-size: 1.1rem; color: var(--color-brass-deep);
    line-height: 1;
  }
  .milestone-title {
    font-family: var(--font-serif); font-size: 1.15rem; line-height: 1.2; margin-top: 0.4rem;
    color: var(--color-ink);
  }
  .milestone-body { font-size: 0.9rem; line-height: 1.55; color: var(--color-charcoal); margin-top: 0.4rem; max-width: 40ch; }

  .principles {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: 1fr; gap: 1px;
    background: rgba(14,15,17,0.08);
    border-block: 1px solid rgba(14,15,17,0.08);
  }
  @media (min-width: 720px) { .principles { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1100px) { .principles { grid-template-columns: 1fr 1fr 1fr; } }
  .principle { background: var(--color-paper); padding: 2rem 1.75rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .principle-name { font-family: var(--font-serif); font-size: 1.3rem; line-height: 1.2; color: var(--color-ink); }
  .principle-body { font-size: 0.94rem; line-height: 1.6; color: var(--color-charcoal); max-width: 40ch; }

  .workshop-grid {
    display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center; margin-bottom: 3rem;
  }
  @media (min-width: 900px) { .workshop-grid { grid-template-columns: 1fr 1fr; gap: 4rem; } }
  .workshop-figure { margin: 0; aspect-ratio: 4/3; background: var(--color-paper); }
  .workshop-figure img { width: 100%; height: 100%; object-fit: cover; }
  .workshop-text p { font-size: 1rem; line-height: 1.7; color: var(--color-charcoal); margin-bottom: 1rem; max-width: 50ch; }
  .workshop-text strong { color: var(--color-ink); font-weight: 500; }
</style>
