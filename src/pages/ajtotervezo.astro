---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import LockBrandWall from "../components/LockBrandWall.astro";
import ContactCTA from "../components/ContactCTA.astro";
import { SITE, SLA, CONTACT } from "../data/site";
import {
  FRAME_COLOURS,
  CLADDING_TYPES_EXTERIOR,
  CLADDING_TYPES_INTERIOR,
  WOOD_PATTERNS,
  MILLED_PATTERNS,
  WOOD_COLOURS,
  MART_COLOURS,
  LOCKS,
  STEPS,
} from "../data/configurator-catalogue";
import type { SwatchPaint, ConfigOption } from "../data/configurator-catalogue";

// Prerendered — this page is fully static. The dynamic part lives in
// the inline browser script + the /api/lead endpoint.
export const prerender = true;

const title = "Ajtótervező — Tervezze meg saját biztonsági ajtaját";
const description = "Modern biztonsági ajtó tervezője 9 lépésben: tokszín, külső és belső borítás, mintázat, szín és zár. Kistarcsai gyártás, MABISZ-minősítés, ingyenes helyszíni felmérés.";

const paint = (s: SwatchPaint): string => {
  if (s.kind === "solid") return s.color;
  const angle = s.angle ?? 135;
  return `linear-gradient(${angle}deg, ${s.from} 0%, ${s.to} 100%)`;
};

const optionSwatch = (opt: ConfigOption) => paint(opt.swatch);
---

<BaseLayout title={title} description={description} bodyClass="page-configurator">
  <!-- Header strip -->
  <section class="cfg-intro">
    <div class="container cfg-intro-inner">
      <div class="cfg-intro-text">
        <p class="eyebrow"><span class="tricolor-strip" aria-hidden="true"><span/><span/><span/></span> Ajtótervező</p>
        <h1 class="cfg-h1">Tervezze meg <em>saját</em> biztonsági ajtaját</h1>
        <p class="cfg-lead">Modern családi és belvárosi biztonsági ajtókhoz. Kilenc lépés, körülbelül 3 perc. A pontos ár a helyszíni felmérés után válik véglegessé — a tervezőben kapott összeg tájékoztató jellegű.</p>
      </div>
      <aside class="cfg-intro-aside">
        <p class="cfg-price-label">Ajánlott ár</p>
        <p class="cfg-price-from"><span data-price>{SITE.priceFromHUF.toLocaleString("hu-HU").replace(/,/g, " ")} Ft-tól</span></p>
        <p class="cfg-price-note">{SLA.surveyDays} alatt felmérjük, {SLA.manufactureDays} alatt gyártjuk, {SLA.installDays} alatt beépítjük.</p>
      </aside>
    </div>
  </section>

  <!-- Workshop / wizard -->
  <section class="cfg-shop">
    <div class="container cfg-shop-inner" data-configurator-root>

      <!-- LEFT — live preview -->
      <div class="cfg-stage">
        <div class="cfg-view-toggle" role="tablist" aria-label="Külső / belső nézet">
          <button type="button" data-view-toggle="ext" aria-pressed="true" class="is-active">Külső nézet</button>
          <button type="button" data-view-toggle="int" aria-pressed="false">Belső nézet</button>
        </div>

        <div class="cfg-preview" aria-live="polite">
          <div class="cfg-door cfg-preview-ext is-visible" data-preview="ext">
            <div class="cfg-frame" data-preview-frame></div>
            <div class="cfg-leaf" data-preview-leaf>
              <div class="cfg-leaf-pattern"></div>
              <div class="cfg-handle" aria-hidden="true"></div>
            </div>
          </div>
          <div class="cfg-door cfg-preview-int" data-preview="int">
            <div class="cfg-frame" data-preview-frame></div>
            <div class="cfg-leaf" data-preview-leaf>
              <div class="cfg-leaf-pattern"></div>
              <div class="cfg-handle" aria-hidden="true"></div>
            </div>
          </div>
          <div class="cfg-preview-note" aria-hidden="true">Illusztratív előnézet — a gyártott ajtó a választott eredeti minta alapján készül.</div>
        </div>

        <div class="cfg-stage-trust">
          <span>MABISZ-minősített 2009 óta</span>
          <span aria-hidden="true">·</span>
          <span>15 év szerkezeti garancia</span>
          <span aria-hidden="true">·</span>
          <span>Kistarcsai műhely</span>
        </div>
      </div>

      <!-- CENTER — wizard step content -->
      <div class="cfg-wizard">
        <!-- Step indicator -->
        <ol class="cfg-steps" aria-label="Lépések">
          {STEPS.map((step) => (
            <li>
              <button type="button" class="cfg-step-dot" data-step-dot={step.id}>
                <span class="cfg-step-num">{step.number}</span>
                <span class="cfg-step-label">{step.label}</span>
              </button>
            </li>
          ))}
        </ol>

        <!-- Step 1: Tokszín -->
        <section class="cfg-step-panel" data-step="frame" aria-labelledby="cfg-h-frame">
          <header>
            <p class="cfg-step-eyebrow">1 / 9 — Tokszín</p>
            <h2 class="cfg-step-h" id="cfg-h-frame">Válassza ki az ajtótok színét</h2>
            <p class="cfg-step-hint">A tok kerete az ajtó fix része — érdemes a falszínhez vagy a homlokzathoz hangolni.</p>
          </header>
          <div class="cfg-grid cfg-grid-swatches">
            {FRAME_COLOURS.map((opt) => (
              <button type="button"
                class="cfg-swatch"
                data-option={opt.id}
                data-option-step="frame"
                data-label={opt.label}
                data-swatch={optionSwatch(opt)}
                aria-pressed="false"
              >
                <span class="cfg-swatch-paint" style={`background:${optionSwatch(opt)}`}></span>
                <span class="cfg-swatch-meta">
                  <span class="cfg-swatch-label">{opt.label}</span>
                  {opt.hint && <span class="cfg-swatch-hint">{opt.hint}</span>}
                </span>
              </button>
            ))}
          </div>
        </section>

        <!-- Step 2: Külső borítás -->
        <section class="cfg-step-panel" data-step="ext-type" aria-labelledby="cfg-h-ext-type">
          <header>
            <p class="cfg-step-eyebrow">2 / 9 — Külső borítás</p>
            <h2 class="cfg-step-h" id="cfg-h-ext-type">Milyen legyen kívülről?</h2>
            <p class="cfg-step-hint">Fa vagy mart minta — a választás befolyásolja a következő lépés mintáit.</p>
          </header>
          <div class="cfg-grid cfg-grid-cards">
            {CLADDING_TYPES_EXTERIOR.map((opt) => (
              <button type="button"
                class="cfg-card"
                data-option={opt.id}
                data-option-step="ext-type"
                data-label={opt.label}
                data-swatch={optionSwatch(opt)}
                aria-pressed="false"
              >
                <span class="cfg-card-paint" style={`background:${optionSwatch(opt)}`}></span>
                <span class="cfg-card-meta">
                  <span class="cfg-card-label">{opt.label}</span>
                  {opt.hint && <span class="cfg-card-hint">{opt.hint}</span>}
                </span>
              </button>
            ))}
          </div>
        </section>

        <!-- Step 3: Külső mintázat (depends on Step 2) -->
        <section class="cfg-step-panel" data-step="ext-pattern" aria-labelledby="cfg-h-ext-pattern">
          <header>
            <p class="cfg-step-eyebrow">3 / 9 — Külső mintázat</p>
            <h2 class="cfg-step-h" id="cfg-h-ext-pattern">Külső mintázat kiválasztása</h2>
            <p class="cfg-step-hint">35 fa kombináció vagy 15 mart minta — a 2. lépésben tett választás alapján.</p>
          </header>
          <div data-pattern-group="fa" class="cfg-grid cfg-grid-patterns is-hidden">
            {WOOD_PATTERNS.map((opt) => (
              <button type="button"
                class="cfg-swatch cfg-swatch-sm"
                data-option={opt.id}
                data-option-step="ext-pattern"
                data-label={opt.label}
                data-swatch={optionSwatch(opt)}
                aria-pressed="false"
              >
                <span class="cfg-swatch-paint" style={`background:${optionSwatch(opt)}`}></span>
                <span class="cfg-swatch-meta">
                  <span class="cfg-swatch-label">{opt.label}</span>
                </span>
              </button>
            ))}
          </div>
          <div data-pattern-group="mart" class="cfg-grid cfg-grid-patterns is-hidden">
            {MILLED_PATTERNS.map((opt) => (
              <button type="button"
                class="cfg-swatch cfg-swatch-sm"
                data-option={opt.id}
                data-option-step="ext-pattern"
                data-label={opt.label}
                data-swatch={optionSwatch(opt)}
                aria-pressed="false"
              >
                <span class="cfg-swatch-paint" style={`background:${optionSwatch(opt)}`}></span>
                <span class="cfg-swatch-meta">
                  <span class="cfg-swatch-label">{opt.label}</span>
                </span>
              </button>
            ))}
          </div>
        </section>

        <!-- Step 4: Külső szín -->
        <section class="cfg-step-panel" data-step="ext-colour" aria-labelledby="cfg-h-ext-colour">
          <header>
            <p class="cfg-step-eyebrow">4 / 9 — Külső szín</p>
            <h2 class="cfg-step-h" id="cfg-h-ext-colour">Külső szín kiválasztása</h2>
            <p class="cfg-step-hint">A mintázathoz hangolt árnyalat.</p>
          </header>
          <div data-colour-group="fa" class="cfg-grid cfg-grid-swatches is-hidden">
            {WOOD_COLOURS.map((opt) => (
              <button type="button"
                class="cfg-swatch"
                data-option={opt.id}
                data-option-step="ext-colour"
                data-label={opt.label}
                data-swatch={optionSwatch(opt)}
                aria-pressed="false"
              >
                <span class="cfg-swatch-paint" style={`background:${optionSwatch(opt)}`}></span>
                <span class="cfg-swatch-meta">
                  <span class="cfg-swatch-label">{opt.label}</span>
                  {opt.hint && <span class="cfg-swatch-hint">{opt.hint}</span>}
                </span>
              </button>
            ))}
          </div>
          <div data-colour-group="mart" class="cfg-grid cfg-grid-swatches is-hidden">
            {MART_COLOURS.map((opt) => (
              <button type="button"
                class="cfg-swatch"
                data-option={opt.id}
                data-option-step="ext-colour"
                data-label={opt.label}
                data-swatch={optionSwatch(opt)}
                aria-pressed="false"
              >
                <span class="cfg-swatch-paint" style={`background:${optionSwatch(opt)}`}></span>
                <span class="cfg-swatch-meta">
                  <span class="cfg-swatch-label">{opt.label}</span>
                  {opt.hint && <span class="cfg-swatch-hint">{opt.hint}</span>}
                </span>
              </button>
            ))}
          </div>
        </section>

        <!-- Step 5: Belső borítás -->
        <section class="cfg-step-panel" data-step="int-type" aria-labelledby="cfg-h-int-type">
          <header>
            <p class="cfg-step-eyebrow">5 / 9 — Belső borítás</p>
            <h2 class="cfg-step-h" id="cfg-h-int-type">Milyen legyen belülről?</h2>
            <p class="cfg-step-hint">Belül választhat eltérő borítást — vagy hagyhatja megegyezőként a külsővel.</p>
          </header>
          <div class="cfg-grid cfg-grid-cards">
            {CLADDING_TYPES_INTERIOR.map((opt) => (
              <button type="button"
                class="cfg-card"
                data-option={opt.id}
                data-option-step="int-type"
                data-label={opt.label}
                data-swatch={optionSwatch(opt)}
                aria-pressed="false"
              >
                <span class="cfg-card-paint" style={`background:${optionSwatch(opt)}`}></span>
                <span class="cfg-card-meta">
                  <span class="cfg-card-label">{opt.label}</span>
                  {opt.hint && <span class="cfg-card-hint">{opt.hint}</span>}
                </span>
              </button>
            ))}
          </div>
        </section>

        <!-- Step 6: Belső mintázat -->
        <section class="cfg-step-panel" data-step="int-pattern" aria-labelledby="cfg-h-int-pattern">
          <header>
            <p class="cfg-step-eyebrow">6 / 9 — Belső mintázat</p>
            <h2 class="cfg-step-h" id="cfg-h-int-pattern">Belső mintázat kiválasztása</h2>
            <p class="cfg-step-hint">Ugyanaz a katalógus, mint a külső oldalon.</p>
          </header>
          <div data-pattern-group="fa" class="cfg-grid cfg-grid-patterns is-hidden">
            {WOOD_PATTERNS.map((opt) => (
              <button type="button"
                class="cfg-swatch cfg-swatch-sm"
                data-option={opt.id}
                data-option-step="int-pattern"
                data-label={opt.label}
                data-swatch={optionSwatch(opt)}
                aria-pressed="false"
              >
                <span class="cfg-swatch-paint" style={`background:${optionSwatch(opt)}`}></span>
                <span class="cfg-swatch-meta">
                  <span class="cfg-swatch-label">{opt.label}</span>
                </span>
              </button>
            ))}
          </div>
          <div data-pattern-group="mart" class="cfg-grid cfg-grid-patterns is-hidden">
            {MILLED_PATTERNS.map((opt) => (
              <button type="button"
                class="cfg-swatch cfg-swatch-sm"
                data-option={opt.id}
                data-option-step="int-pattern"
                data-label={opt.label}
                data-swatch={optionSwatch(opt)}
                aria-pressed="false"
              >
                <span class="cfg-swatch-paint" style={`background:${optionSwatch(opt)}`}></span>
                <span class="cfg-swatch-meta">
                  <span class="cfg-swatch-label">{opt.label}</span>
                </span>
              </button>
            ))}
          </div>
        </section>

        <!-- Step 7: Belső szín -->
        <section class="cfg-step-panel" data-step="int-colour" aria-labelledby="cfg-h-int-colour">
          <header>
            <p class="cfg-step-eyebrow">7 / 9 — Belső szín</p>
            <h2 class="cfg-step-h" id="cfg-h-int-colour">Belső szín kiválasztása</h2>
            <p class="cfg-step-hint">Belső térhez hangolt árnyalat.</p>
          </header>
          <div data-colour-group="fa" class="cfg-grid cfg-grid-swatches is-hidden">
            {WOOD_COLOURS.map((opt) => (
              <button type="button"
                class="cfg-swatch"
                data-option={opt.id}
                data-option-step="int-colour"
                data-label={opt.label}
                data-swatch={optionSwatch(opt)}
                aria-pressed="false"
              >
                <span class="cfg-swatch-paint" style={`background:${optionSwatch(opt)}`}></span>
                <span class="cfg-swatch-meta">
                  <span class="cfg-swatch-label">{opt.label}</span>
                  {opt.hint && <span class="cfg-swatch-hint">{opt.hint}</span>}
                </span>
              </button>
            ))}
          </div>
          <div data-colour-group="mart" class="cfg-grid cfg-grid-swatches is-hidden">
            {MART_COLOURS.map((opt) => (
              <button type="button"
                class="cfg-swatch"
                data-option={opt.id}
                data-option-step="int-colour"
                data-label={opt.label}
                data-swatch={optionSwatch(opt)}
                aria-pressed="false"
              >
                <span class="cfg-swatch-paint" style={`background:${optionSwatch(opt)}`}></span>
                <span class="cfg-swatch-meta">
                  <span class="cfg-swatch-label">{opt.label}</span>
                  {opt.hint && <span class="cfg-swatch-hint">{opt.hint}</span>}
                </span>
              </button>
            ))}
          </div>
        </section>

        <!-- Step 8: Zár -->
        <section class="cfg-step-panel" data-step="lock" aria-labelledby="cfg-h-lock">
          <header>
            <p class="cfg-step-eyebrow">8 / 9 — Zár</p>
            <h2 class="cfg-step-h" id="cfg-h-lock">Válasszon zárrendszert</h2>
            <p class="cfg-step-hint">Öt prémium márka, mindegyik MABISZ-besorolással. A magasabb osztály több perc ellenállási időt jelent.</p>
          </header>
          <div class="cfg-grid cfg-grid-cards">
            {LOCKS.map((lock) => (
              <label class="cfg-lock-card">
                <input type="radio" name="cfg-lock" value={lock.id} data-lock-brand data-label={lock.label} />
                <span class="cfg-lock-paint" style={`background:${optionSwatch(lock)}`}></span>
                <span class="cfg-lock-meta">
                  <span class="cfg-lock-label">{lock.label}</span>
                  <span class="cfg-lock-origin">{lock.origin}</span>
                  {lock.hint && <span class="cfg-lock-hint">{lock.hint}</span>}
                </span>
              </label>
            ))}
          </div>
          <div class="cfg-mabisz-pickers">
            {LOCKS.map((lock) => (
              <fieldset class="cfg-mabisz is-hidden" data-lock-classes={lock.id}>
                <legend>MABISZ-osztály — {lock.label}</legend>
                <div class="cfg-mabisz-grid">
                  {lock.mabiszClasses.map((cls) => (
                    <label class="cfg-mabisz-opt">
                      <input type="radio" name={`cfg-mabisz-${lock.id}`} value={cls.id}
                        data-lock-mabisz
                        data-label={cls.label}
                        data-surcharge={String(cls.surcharge)}
                      />
                      <span class="cfg-mabisz-label">{cls.label}</span>
                      <span class="cfg-mabisz-resistance">{cls.resistance}</span>
                      <span class="cfg-mabisz-price">{cls.surcharge === 0 ? "alapár" : `+${cls.surcharge.toLocaleString("hu-HU").replace(/,/g, " ")} Ft`}</span>
                    </label>
                  ))}
                </div>
              </fieldset>
            ))}
          </div>
        </section>

        <!-- Step 9: Summary / lead form -->
        <section class="cfg-step-panel" data-step="summary" aria-labelledby="cfg-h-summary">
          <header>
            <p class="cfg-step-eyebrow">9 / 9 — Összegzés</p>
            <h2 class="cfg-step-h" id="cfg-h-summary">Foglalja le ingyenes helyszíni felmérését</h2>
            <p class="cfg-step-hint">Kistarcsáról {SLA.surveyDays} alatt érünk Önhöz. Mintamintával, kötelezettség nélkül. A pontos ár a helyszíni felmérés után válik véglegessé.</p>
          </header>

          <form class="cfg-lead-form" data-lead-form novalidate>
            <div class="cfg-lead-grid">
              <label class="cfg-field">
                <span>Név <em aria-hidden="true">*</em></span>
                <input type="text" name="name" required autocomplete="name" placeholder="Kovács Anna" />
              </label>
              <label class="cfg-field">
                <span>Telefon <em aria-hidden="true">*</em></span>
                <input type="tel" name="phone" required autocomplete="tel" placeholder="+36 30 123 4567" />
              </label>
              <label class="cfg-field">
                <span>E-mail</span>
                <input type="email" name="email" autocomplete="email" placeholder="anna@pelda.hu" />
              </label>
              <label class="cfg-field">
                <span>Irányítószám</span>
                <input type="text" name="postcode" inputmode="numeric" pattern="[0-9]{4}" autocomplete="postal-code" placeholder="1141" />
              </label>
              <label class="cfg-field cfg-field-wide">
                <span>Üzenet (opcionális)</span>
                <textarea name="message" rows="3" placeholder="Pl. ajtó méretek, lépcsőházi adottságok, beépítési időpont"></textarea>
              </label>
            </div>

            <!-- Honeypot — bots fill, humans don't see -->
            <label class="cfg-honey" aria-hidden="true">
              <span>Ne töltse ki ezt a mezőt</span>
              <input type="text" name="_honey" tabindex="-1" autocomplete="off" />
            </label>

            <label class="cfg-consent">
              <input type="checkbox" name="consent" required />
              <span>Elolvastam és elfogadom az <a href="/adatvedelem" target="_blank" rel="noopener">adatvédelmi tájékoztatót</a>. <em aria-hidden="true">*</em></span>
            </label>
            <label class="cfg-consent">
              <input type="checkbox" name="marketing" />
              <span>Szeretnék emlékeztetőt és új minta-értesítőt kapni e-mailben (lemondható bármikor).</span>
            </label>

            <div class="cfg-lead-actions">
              <button type="submit" class="btn btn-primary btn-large">Felmérés foglalása →</button>
              <button type="button" class="cfg-save" data-action="save-design">
                Mentem a tervet
                <span class="cfg-tooltip" role="tooltip">Hamarosan elérhető</span>
              </button>
            </div>

            <p class="cfg-lead-status" data-lead-status aria-live="polite"></p>
          </form>

          <div class="cfg-bespoke-route">
            <p>
              <strong>Stílus- vagy műemléki ajtót keres?</strong> Az egyedi, korhű, kazettás vagy festett ajtók nem konfigurálhatók előre.
              <a href="/felmeres?source=ajtotervezo-muemleki">Itt jelezzen felmérést — építészeti felmérőnk az eredeti ajtó alapján tervez Önnek.</a>
            </p>
          </div>
        </section>
      </div>

      <!-- RIGHT — persistent summary panel (collapsible on mobile) -->
      <aside class="cfg-summary">
        <details class="cfg-summary-details" open>
          <summary class="cfg-summary-head">
            <span class="eyebrow">Az Ön terve</span>
            <span class="cfg-summary-price" data-price aria-live="polite">{SITE.priceFromHUF.toLocaleString("hu-HU").replace(/,/g, " ")} Ft-tól</span>
          </summary>
          <dl class="cfg-summary-list">
            <div><dt>Tokszín</dt><dd data-summary-item="frame">—</dd></div>
            <div><dt>Külső borítás</dt><dd data-summary-item="ext-type">—</dd></div>
            <div><dt>Külső mintázat</dt><dd data-summary-item="ext-pattern">—</dd></div>
            <div><dt>Külső szín</dt><dd data-summary-item="ext-colour">—</dd></div>
            <div><dt>Belső borítás</dt><dd data-summary-item="int-type">—</dd></div>
            <div><dt>Belső mintázat</dt><dd data-summary-item="int-pattern">—</dd></div>
            <div><dt>Belső szín</dt><dd data-summary-item="int-colour">—</dd></div>
            <div><dt>Zár</dt><dd data-summary-item="lock">—</dd></div>
          </dl>
          <p class="cfg-summary-note">Az ár tájékoztató — a végleges összeg helyszíni felmérés után válik fixxé.</p>
        </details>
      </aside>

    </div>
  </section>

  <!-- Sticky mobile bottom bar -->
  <div class="cfg-mobile-bar" role="region" aria-label="Lépésnavigáció">
    <button type="button" data-action="back" class="cfg-mobile-back" aria-label="Vissza">← Vissza</button>
    <div class="cfg-mobile-mid">
      <span class="cfg-mobile-counter" data-step-counter>1 / 9</span>
      <span class="cfg-mobile-price" data-price>{SITE.priceFromHUF.toLocaleString("hu-HU").replace(/,/g, " ")} Ft-tól</span>
    </div>
    <button type="button" data-action="next" class="cfg-mobile-next">Tovább →</button>
  </div>

  <!-- Trust + reinforcement -->
  <Section tone="cream" eyebrow="33 éve készítünk biztonsági ajtókat Kistarcsán"
    heading="Miért a Huba ajtó tervezője?"
    lead="A tervező nem kötelezi semmire — Ön nyugodtan próbálgathat. Amikor készen áll, mi a helyszínen felmérjük, és pontos árajánlatot adunk a meglévő nyílásra.">
    <div class="cfg-trust-grid stagger">
      <div class="cfg-trust-card">
        <p class="eyebrow">Saját gyártás</p>
        <h3>Kistarcsai műhelyünk</h3>
        <p>Minden ajtó nálunk készül — hőhídmentes acél zártszelvény tokkal, üveggyapot béleléssel, körbefutó tömítéssel.</p>
      </div>
      <div class="cfg-trust-card">
        <p class="eyebrow">MABISZ + RC</p>
        <h3>2. – 4. osztály</h3>
        <p>Mottura, Abus, Mul-T-Lock, Iseo, Cisa zárakkal. MABISZ-minősítés a teljes ajtószerkezetre, nem csak a zárra.</p>
      </div>
      <div class="cfg-trust-card">
        <p class="eyebrow">{SITE.warrantyYears} év szerkezeti garancia</p>
        <h3>A piac leghosszabb vállalása</h3>
        <p>Magyarországon nincs még egy gyártó, aki ennyi szerkezeti garanciát adna a bejárati ajtóra.</p>
      </div>
      <div class="cfg-trust-card">
        <p class="eyebrow">Felmérés → Beépítés</p>
        <h3>{SLA.surveyDays} + {SLA.manufactureDays} + {SLA.installDays}</h3>
        <p>Felmérés Önöknél, gyártás Kistarcsán, beépítés egy nap alatt — bontás és falbontás nélkül.</p>
      </div>
    </div>
  </Section>

  <LockBrandWall />

  <ContactCTA
    heading="Készen áll a felmérésre?"
    lead={`Adja meg az adatait a tervezőben, vagy hívjon minket közvetlenül — H–P 8:00–17:00 között a ${CONTACT.phonePrimary} számon.`}
  />
</BaseLayout>

<style is:global>
  .page-configurator main { background: var(--color-paper); }

  /* ── INTRO ───────────────────────────────────────────── */
  .cfg-intro { background: var(--color-paper); padding: clamp(2.5rem, 5vw, 4rem) 0 1rem; }
  .cfg-intro-inner { display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: end; }
  @media (min-width: 900px) { .cfg-intro-inner { grid-template-columns: 1.4fr 1fr; gap: 4rem; } }
  .cfg-h1 { font-family: var(--font-serif); font-size: clamp(2.4rem, 5vw, 4rem); line-height: 1.02; letter-spacing: -0.018em; margin-top: 0.4rem; max-width: 18ch; }
  .cfg-h1 em { font-style: italic; color: var(--color-brass-deep); }
  .cfg-lead { font-family: var(--font-serif); font-size: 1.2rem; line-height: 1.45; color: var(--color-charcoal); max-width: 44ch; margin-top: 1rem; }
  .cfg-intro-aside {
    background: var(--color-cream); padding: 1.5rem 1.75rem; border: 1px solid rgba(14,15,17,0.08);
    border-radius: 2px;
  }
  .cfg-price-label { font-size: 0.72rem; letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--color-stone); }
  .cfg-price-from { font-family: var(--font-serif); font-size: 2rem; line-height: 1; margin-top: 0.4rem; color: var(--color-ink); }
  .cfg-price-note { font-size: 0.9rem; margin-top: 0.6rem; color: var(--color-charcoal); }

  /* ── WORKSHOP / WIZARD LAYOUT ────────────────────────── */
  .cfg-shop { padding: 1.5rem 0 6rem; }
  .cfg-shop-inner {
    display: grid; grid-template-columns: 1fr; gap: 1.5rem;
  }
  @media (min-width: 900px) {
    .cfg-shop-inner {
      grid-template-columns: minmax(280px, 360px) minmax(0, 1fr) minmax(260px, 320px);
      gap: 2rem;
      align-items: start;
    }
  }
  @media (min-width: 900px) {
    .cfg-stage    { position: sticky; top: 6rem; }
    .cfg-summary  { position: sticky; top: 6rem; }
  }

  /* ── PREVIEW / STAGE ─────────────────────────────────── */
  .cfg-view-toggle {
    display: flex; gap: 0.25rem; border: 1px solid var(--color-ink);
    background: var(--color-paper); width: fit-content; margin-bottom: 1rem;
  }
  .cfg-view-toggle button {
    appearance: none; background: transparent; border: none;
    padding: 0.55rem 1rem; font: inherit; font-size: 0.85rem;
    letter-spacing: 0.04em; color: var(--color-ink); cursor: pointer;
    transition: background var(--dur-fast), color var(--dur-fast);
  }
  .cfg-view-toggle button.is-active { background: var(--color-ink); color: var(--color-paper); }

  .cfg-preview {
    position: relative; aspect-ratio: 3 / 4; background: var(--color-cream);
    border: 1px solid rgba(14,15,17,0.1);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }
  .cfg-door {
    position: absolute; inset: 0;
    display: flex; align-items: stretch; justify-content: center;
    padding: clamp(1rem, 3vw, 2rem);
    opacity: 0; transition: opacity var(--dur) var(--ease-out-soft);
  }
  .cfg-door.is-visible { opacity: 1; }
  .cfg-frame {
    position: relative; flex: 1;
    background: #B7BBC1; /* default before any frame chosen */
    transition: background var(--dur) var(--ease-out-soft);
    padding: clamp(0.6rem, 1.5vw, 1rem);
    box-shadow: inset 0 0 0 1px rgba(14,15,17,0.18), 0 12px 30px rgba(14,15,17,0.1);
  }
  .cfg-leaf {
    position: relative; width: 100%; height: 100%;
    background: linear-gradient(135deg, #9B6A36 0%, #4A2A18 100%);
    transition: background var(--dur) var(--ease-out-soft);
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.18), inset 0 12px 30px rgba(255,255,255,0.04);
  }
  .cfg-leaf::before, .cfg-leaf::after {
    content: ""; position: absolute; left: 12%; right: 12%;
    border: 1px solid rgba(255,255,255,0.12);
    pointer-events: none;
  }
  .cfg-leaf::before { top: 12%; bottom: 56%; }
  .cfg-leaf::after  { top: 56%; bottom: 12%; }
  .cfg-handle {
    position: absolute; right: 8%; top: 50%; transform: translateY(-50%);
    width: 4%; aspect-ratio: 1 / 5; background: var(--color-brass);
    box-shadow: 0 0 0 1px rgba(0,0,0,0.2);
  }
  .cfg-preview-note {
    position: absolute; left: 0; right: 0; bottom: 0;
    background: rgba(14,15,17,0.78); color: var(--color-paper);
    font-size: 0.72rem; padding: 0.5rem 0.75rem; text-align: center;
  }
  .cfg-stage-trust {
    margin-top: 0.75rem; font-size: 0.74rem; color: var(--color-stone);
    letter-spacing: 0.04em; display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;
  }

  /* ── WIZARD STEPS ────────────────────────────────────── */
  .cfg-steps {
    display: flex; flex-wrap: wrap; gap: 0.4rem;
    list-style: none; padding: 0; margin: 0 0 1.5rem;
  }
  .cfg-step-dot {
    appearance: none; background: transparent; border: 1px solid rgba(14,15,17,0.18);
    padding: 0.4rem 0.7rem; font: inherit; cursor: pointer; display: flex; align-items: center; gap: 0.4rem;
    color: var(--color-stone); transition: all var(--dur-fast);
    font-size: 0.78rem;
  }
  .cfg-step-dot:hover:not(:disabled) { border-color: var(--color-ink); color: var(--color-ink); }
  .cfg-step-dot.is-active { background: var(--color-ink); color: var(--color-paper); border-color: var(--color-ink); }
  .cfg-step-dot.is-done   { color: var(--color-brass-deep); border-color: var(--color-brass); }
  .cfg-step-num { font-variant-numeric: tabular-nums; font-weight: 500; }
  @media (max-width: 700px) { .cfg-step-label { display: none; } }

  .cfg-step-panel { display: none; }
  .cfg-step-panel.is-active { display: block; }
  .cfg-step-eyebrow { font-size: 0.72rem; letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--color-stone); margin-bottom: 0.4rem; }
  .cfg-step-h { font-family: var(--font-serif); font-size: clamp(1.5rem, 2.4vw, 2.1rem); line-height: 1.1; max-width: 22ch; }
  .cfg-step-hint { color: var(--color-charcoal); margin-top: 0.6rem; max-width: 48ch; }

  .cfg-grid { display: grid; gap: 0.75rem; margin-top: 1.25rem; }
  .cfg-grid-swatches { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
  .cfg-grid-cards    { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
  .cfg-grid-patterns { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); }
  .is-hidden { display: none !important; }

  /* ── SWATCH BUTTON ───────────────────────────────────── */
  .cfg-swatch {
    appearance: none; background: var(--color-canvas); border: 1px solid rgba(14,15,17,0.12);
    padding: 0; cursor: pointer; text-align: left; font: inherit;
    display: flex; flex-direction: column; transition: all var(--dur-fast);
    overflow: hidden;
  }
  .cfg-swatch:hover { border-color: var(--color-ink); transform: translateY(-1px); box-shadow: var(--shadow-soft); }
  .cfg-swatch.is-selected { border-color: var(--color-brass); box-shadow: 0 0 0 2px var(--color-brass); }
  .cfg-swatch-paint { display: block; width: 100%; aspect-ratio: 4 / 3; background: var(--color-mist); }
  .cfg-swatch-sm .cfg-swatch-paint { aspect-ratio: 1 / 1; }
  .cfg-swatch-meta { display: flex; flex-direction: column; gap: 0.15rem; padding: 0.5rem 0.65rem 0.65rem; min-height: 2.2rem; }
  .cfg-swatch-label { font-size: 0.82rem; font-weight: 500; color: var(--color-ink); }
  .cfg-swatch-hint  { font-size: 0.72rem; color: var(--color-stone); }

  /* ── CARD BUTTON (cladding type, locks) ─────────────── */
  .cfg-card {
    appearance: none; background: var(--color-canvas); border: 1px solid rgba(14,15,17,0.12);
    padding: 0; cursor: pointer; text-align: left; font: inherit;
    display: flex; gap: 0.85rem; align-items: stretch; overflow: hidden;
    transition: all var(--dur-fast); min-height: 96px;
  }
  .cfg-card:hover { border-color: var(--color-ink); transform: translateY(-1px); box-shadow: var(--shadow-soft); }
  .cfg-card.is-selected { border-color: var(--color-brass); box-shadow: 0 0 0 2px var(--color-brass); }
  .cfg-card-paint { width: 28%; min-width: 80px; background: var(--color-mist); }
  .cfg-card-meta  { display: flex; flex-direction: column; gap: 0.25rem; padding: 0.9rem 1rem; }
  .cfg-card-label { font-family: var(--font-serif); font-size: 1.15rem; color: var(--color-ink); }
  .cfg-card-hint  { font-size: 0.85rem; color: var(--color-stone); line-height: 1.35; }

  /* ── LOCK PICKER ─────────────────────────────────────── */
  .cfg-lock-card {
    display: flex; gap: 0.85rem; align-items: stretch; cursor: pointer;
    background: var(--color-canvas); border: 1px solid rgba(14,15,17,0.12);
    padding: 0; min-height: 96px; overflow: hidden; transition: all var(--dur-fast);
    position: relative;
  }
  .cfg-lock-card input { position: absolute; opacity: 0; inset: 0; cursor: pointer; }
  .cfg-lock-card:has(input:checked) { border-color: var(--color-brass); box-shadow: 0 0 0 2px var(--color-brass); }
  .cfg-lock-card:hover { border-color: var(--color-ink); }
  .cfg-lock-paint { width: 28%; min-width: 80px; background: var(--color-mist); }
  .cfg-lock-meta  { display: flex; flex-direction: column; gap: 0.2rem; padding: 0.9rem 1rem; }
  .cfg-lock-label { font-family: var(--font-serif); font-size: 1.2rem; }
  .cfg-lock-origin{ font-size: 0.72rem; letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--color-brass-deep); }
  .cfg-lock-hint  { font-size: 0.85rem; color: var(--color-stone); }

  .cfg-mabisz-pickers { margin-top: 1.5rem; }
  .cfg-mabisz { border: 1px solid rgba(14,15,17,0.12); padding: 1rem 1.2rem; background: var(--color-cream); }
  .cfg-mabisz legend { font-size: 0.78rem; padding: 0 0.4rem; letter-spacing: 0.04em; }
  .cfg-mabisz-grid { display: grid; gap: 0.5rem; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); margin-top: 0.5rem; }
  .cfg-mabisz-opt {
    display: grid; grid-template-columns: auto 1fr auto; column-gap: 0.5rem;
    row-gap: 0.15rem; align-items: center; padding: 0.65rem 0.8rem;
    background: var(--color-canvas); border: 1px solid rgba(14,15,17,0.1); cursor: pointer;
    transition: all var(--dur-fast);
  }
  .cfg-mabisz-opt:has(input:checked) { border-color: var(--color-brass); box-shadow: 0 0 0 2px var(--color-brass); }
  .cfg-mabisz-label { grid-column: 2; font-weight: 500; }
  .cfg-mabisz-resistance { grid-column: 2; font-size: 0.78rem; color: var(--color-stone); }
  .cfg-mabisz-price { grid-column: 3; grid-row: 1 / 3; font-size: 0.85rem; color: var(--color-brass-deep); font-variant-numeric: tabular-nums; }

  /* ── SUMMARY PANEL ───────────────────────────────────── */
  .cfg-summary {
    background: var(--color-canvas); border: 1px solid rgba(14,15,17,0.08);
    padding: 1.25rem; box-shadow: var(--shadow-soft);
  }
  .cfg-summary-details summary { list-style: none; cursor: pointer; }
  .cfg-summary-details summary::-webkit-details-marker { display: none; }
  .cfg-summary-head { display: flex; flex-direction: column; gap: 0.5rem; }
  .cfg-summary-price { font-family: var(--font-serif); font-size: 1.5rem; }
  .cfg-summary-list { margin: 1.25rem 0 0; display: flex; flex-direction: column; gap: 0.55rem; }
  .cfg-summary-list > div { display: grid; grid-template-columns: 1fr 1fr; align-items: baseline; gap: 0.5rem; border-bottom: 1px solid rgba(14,15,17,0.06); padding-bottom: 0.4rem; }
  .cfg-summary-list dt { font-size: 0.78rem; color: var(--color-stone); letter-spacing: 0.03em; }
  .cfg-summary-list dd { margin: 0; font-size: 0.92rem; color: var(--color-ink); text-align: right; }
  .cfg-summary-note { margin-top: 1rem; font-size: 0.78rem; color: var(--color-stone); line-height: 1.45; }

  /* ── LEAD FORM ───────────────────────────────────────── */
  .cfg-lead-form { margin-top: 1.5rem; background: var(--color-canvas); border: 1px solid rgba(14,15,17,0.1); padding: clamp(1.25rem, 2.5vw, 1.75rem); }
  .cfg-lead-grid { display: grid; gap: 1rem; grid-template-columns: 1fr 1fr; }
  @media (max-width: 600px) { .cfg-lead-grid { grid-template-columns: 1fr; } }
  .cfg-field { display: flex; flex-direction: column; gap: 0.35rem; font-size: 0.85rem; }
  .cfg-field > span { font-size: 0.78rem; letter-spacing: 0.04em; color: var(--color-charcoal); }
  .cfg-field em { color: var(--color-brass-deep); }
  .cfg-field input, .cfg-field textarea {
    appearance: none; background: var(--color-canvas); border: 1px solid rgba(14,15,17,0.18);
    padding: 0.65rem 0.8rem; font: inherit; font-size: 0.95rem; color: var(--color-ink);
    transition: border-color var(--dur-fast);
  }
  .cfg-field input:focus, .cfg-field textarea:focus { outline: none; border-color: var(--color-ink); }
  .cfg-field-wide { grid-column: 1 / -1; }
  .cfg-honey { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .cfg-consent { display: flex; gap: 0.5rem; align-items: flex-start; margin-top: 0.85rem; font-size: 0.85rem; }
  .cfg-consent a { color: var(--color-brass-deep); text-decoration: underline; }
  .cfg-lead-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; align-items: center; margin-top: 1.5rem; }
  .cfg-save { position: relative; appearance: none; background: transparent; border: 1px dashed rgba(14,15,17,0.25); color: var(--color-stone); padding: 0.85rem 1.2rem; font: inherit; cursor: pointer; }
  .cfg-save:hover { color: var(--color-ink); border-color: var(--color-ink); }
  .cfg-tooltip {
    position: absolute; left: 50%; bottom: calc(100% + 6px); transform: translateX(-50%);
    background: var(--color-ink); color: var(--color-paper);
    padding: 0.35rem 0.7rem; font-size: 0.72rem; opacity: 0; pointer-events: none;
    transition: opacity var(--dur-fast); white-space: nowrap;
  }
  .cfg-tooltip.is-visible { opacity: 1; }
  .cfg-lead-status { margin-top: 1rem; font-size: 0.88rem; min-height: 1.4em; }
  .cfg-lead-status.is-loading { color: var(--color-stone); }
  .cfg-lead-status.is-ok      { color: var(--color-flag-green); }
  .cfg-lead-status.is-error   { color: var(--color-flag-red); }

  .cfg-bespoke-route {
    margin-top: 1.5rem; padding: 1rem 1.2rem; background: var(--color-cream);
    border-left: 3px solid var(--color-brass); font-size: 0.92rem; color: var(--color-charcoal);
  }
  .cfg-bespoke-route a { color: var(--color-brass-deep); text-decoration: underline; margin-left: 0.25em; }

  /* ── MOBILE STICKY BAR ───────────────────────────────── */
  .cfg-mobile-bar {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 40;
    background: var(--color-ink); color: var(--color-paper);
    display: none; align-items: center; gap: 0.5rem;
    padding: 0.6rem 0.85rem; box-shadow: 0 -8px 24px rgba(14,15,17,0.18);
  }
  @media (max-width: 899px) { .cfg-mobile-bar { display: flex; } .cfg-shop-inner { padding-bottom: 5rem; } }
  .cfg-mobile-bar button {
    appearance: none; background: transparent; border: 1px solid rgba(255,255,255,0.3);
    color: inherit; padding: 0.55rem 0.85rem; font: inherit; font-size: 0.85rem; cursor: pointer;
  }
  .cfg-mobile-bar button:disabled { opacity: 0.4; }
  .cfg-mobile-mid { flex: 1; display: flex; flex-direction: column; align-items: center; }
  .cfg-mobile-counter { font-size: 0.7rem; letter-spacing: 0.06em; color: var(--color-mist); }
  .cfg-mobile-price   { font-size: 0.95rem; font-family: var(--font-serif); }

  /* ── TRUST GRID ─────────────────────────────────────── */
  .cfg-trust-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-top: 1rem; }
  .cfg-trust-card { background: var(--color-canvas); padding: 1.5rem; border: 1px solid rgba(14,15,17,0.08); }
  .cfg-trust-card h3 { font-family: var(--font-serif); font-size: 1.4rem; margin-top: 0.3rem; }
  .cfg-trust-card p  { color: var(--color-charcoal); margin-top: 0.5rem; font-size: 0.95rem; line-height: 1.45; }
</style>

<script>
  import { initConfigurator } from "../lib/configurator";

  const boot = () => {
    const root = document.querySelector<HTMLElement>("[data-configurator-root]");
    if (root) initConfigurator(root);
  };

  boot();
  document.addEventListener("astro:page-load", boot);
</script>
</BaseLayout>
