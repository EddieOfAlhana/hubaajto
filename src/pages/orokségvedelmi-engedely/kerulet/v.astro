---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import Section from "../../../components/Section.astro";
import ContactCTA from "../../../components/ContactCTA.astro";
import { SLA } from "../../../data/site";
---

<BaseLayout
  title="Belváros-Lipótváros (V.) — örökségvédelmi engedély ajtócseréhez"
  description="Az V. kerület (Belváros-Lipótváros) ajtócseréinek szabályozása az 5/2020. (I. 30.) önkormányzati rendelet alapján. Tervtanácsi vélemény, polgári bérházak, klasszicista homlokzatok — a Huba ajtó engedélyezési csomagjával."
>
  <Hero
    eyebrow="Budapest · V. kerület"
    heading="Belváros-Lipótváros — <em>tervtanácsi gyakorlat.</em>"
    lead="Az V. kerület klasszicista és eklektikus polgári bérházállományánál az engedélyezés rendre tervtanácsi véleményhez kötött. Az 5/2020. (I. 30.) önkormányzati rendelet és a Belváros-Lipótváros KÉSZ által meghatározott szabályozás a magyar fővárosi belváros legszigorúbb előírásainak egyike."
    image="/assets/photos/hero/period-double-leaf.jpg"
    imageAlt="Belvárosi kétszárnyú polgári biztonsági ajtó kovácsoltvas filigrán panelokkal"
    imageCaption="Belváros-Lipótváros · klasszikus portfólió"
    primaryCta={{ label: "Felmérés foglalása", href: "/felmeres" }}
    secondaryCta={{ label: "Vissza az útmutatóhoz", href: "/orokségvedelmi-engedely" }}
  />

  <div id="below"></div>

  <Section
    tone="paper"
    eyebrow="A kerületi szabályozás"
    heading="5/2020. (I. 30.) rendelet — tervtanácsi vélemény."
  >
    <p class="lead-text reveal">
      A Belváros-Lipótváros (V. kerület) önkormányzata az 5/2020. (I. 30.) rendelettel a teljes
      bérházállományra részletes településképvédelmi szabályozást alakított ki. A rendelet
      kulcseleme: a homlokzati nyílászárót érintő munkáknál a kerületi tervtanács szakmai véleményét
      kötelező lehet bekérni — ez plusz 2-4 hét időkeretet jelent a folyamatban.
    </p>
  </Section>

  <Section
    tone="cream"
    eyebrow="Mit szabályoz konkrétan?"
    heading="A klasszicista polgári arc megőrzése."
  >
    <ul class="bullet-list">
      <li>
        <strong>Utcafronti kapuk:</strong> a kétszárnyú (kétleveles) polgári bejárati kapuk osztásrendje,
        profilszélessége és vasalata az eredetihez igazodjon. Ez gyakran transzom üvegezett felső
        szakaszt, kovácsolt filigrán rácsbetéteket és sárgaréz fogantyúkat jelent.
      </li>
      <li>
        <strong>Lépcsőházi lakásajtók:</strong> ha a védettségi rendelet vagy a KÉSZ kifejezetten
        szabályozza, településképi bejelentés keretében változtathatók. A nem nevesített elemek is
        bejelentéskötelesek.
      </li>
      <li>
        <strong>Anyaghasználat:</strong> fa, kovácsoltvas, sárgaréz az alapértelmezett. Alumínium vagy
        műanyag az utcai homlokzaton általában nem.
      </li>
      <li>
        <strong>Szín:</strong> az eredeti, az értékleltárból kiolvasható festési hagyományhoz idomulva —
        sok belvárosi bérházban ez sötétzöld vagy gesztenyebarna.
      </li>
    </ul>
  </Section>

  <Section
    tone="paper"
    eyebrow="A folyamat lépései"
    heading="V. kerületi engedélyezés — kibővítve a tervtanáccsal."
  >
    <ol class="process-list">
      <li>
        <strong>Védettségi ellenőrzés</strong> — OÉNY-ben és a V. kerületi főépítészi irodával.
      </li>
      <li>
        <strong>Helyszíni felmérés</strong> — méretek, profilrajz, kovácsoltvas elemek, üvegminta.
      </li>
      <li>
        <strong>Tervdokumentáció + építéstörténeti értékleltár</strong> — építész tervező és műemléki
        szakértői névjegyzéki szakértő partnerünkkel.
      </li>
      <li>
        <strong>Kerületi tervtanácsi prezentáció</strong> — ha kötelező, mi prezentáljuk a tervet.
        Időkeret: +2-4 hét.
      </li>
      <li>
        <strong>ÉTDR engedélykérelem</strong> — 25 nap a Kormányhivatalnál.
      </li>
      <li>
        <strong>Településképi bejelentés</strong> — párhuzamosan, 15 nap.
      </li>
      <li>
        <strong>Gyártás és beépítés</strong> — engedélyezett kivitelben.
      </li>
      <li>
        <strong>Befejezési bejelentés.</strong>
      </li>
    </ol>
    <p class="footnote reveal">
      A tervtanács miatt a V. kerületi átlagos folyamat 5-6 hónap. Az engedélyt mi készítjük elő,
      Önnek a tervtanácson nem kell megjelennie.
    </p>
  </Section>

  <Section
    tone="cream"
    eyebrow="A Huba ajtó V. kerületben"
    heading="Kétszárnyú kapuk és lépcsőházi ajtók."
  >
    <p class="body-text reveal">
      Az V. kerületi munkáinkban a kétszárnyú (kétleveles) polgári kapuk és a lépcsőházi lakásajtók
      adják a többséget. Mindkettőhöz korhű, az eredetihez igazodó kazettás vagy betétes kivitelt
      gyártunk, kovácsoltvas filigrán rácsbetétekkel és sárgaréz vasalattal — belül acélbetétes
      biztonsági szerkezettel, MABISZ-minősítéssel.
    </p>
    <p class="body-text reveal">
      <a href="/muemleki-biztonsagi-ajto">Műemléki biztonsági ajtó — termékoldal →</a>
    </p>
  </Section>

  <ContactCTA
    heading="V. kerületi címre felmérés"
    lead={`Kistarcsáról ${SLA.surveyDays} alatt érünk Önhöz — a védettségi és a tervtanácsi időigényt is mi visszük.`}
  />
</BaseLayout>

<style>
  .lead-text { font-family: var(--font-serif); font-size: 1.2rem; line-height: 1.6; color: var(--color-charcoal); max-width: 60ch; }
  .body-text { font-size: 1rem; line-height: 1.7; color: var(--color-charcoal); max-width: 64ch; margin-top: 1rem; }
  .body-text a { color: var(--color-brass-deep); text-decoration: underline; text-underline-offset: 3px; }

  .bullet-list, .process-list {
    padding: 0; max-width: 64ch; display: flex; flex-direction: column; gap: 0.85rem;
    font-size: 1rem; line-height: 1.6; color: var(--color-charcoal);
  }
  .bullet-list { list-style: none; }
  .bullet-list li { padding-left: 1.25rem; position: relative; }
  .bullet-list li::before { content: ""; position: absolute; left: 0; top: 0.7em; width: 0.55rem; height: 1px; background: var(--color-brass); }
  .bullet-list strong { color: var(--color-ink); }
  .process-list { list-style: decimal; padding-left: 1.5rem; }
  .process-list strong { color: var(--color-ink); }

  .footnote { margin-top: 1.5rem; font-size: 0.95rem; color: var(--color-stone); max-width: 64ch; }
  .footnote strong { color: var(--color-ink); }
</style>
