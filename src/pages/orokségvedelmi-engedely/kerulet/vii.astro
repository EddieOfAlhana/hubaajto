---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import Section from "../../../components/Section.astro";
import ContactCTA from "../../../components/ContactCTA.astro";
import { SLA } from "../../../data/site";
---

<BaseLayout
  title="Erzsébetváros (VII.) — örökségvédelmi engedély ajtócseréhez"
  description="A VII. kerület (Erzsébetváros) ajtócseréinek szabályozása a 25/2017. településképi rendelet és az Erzsébetváros Építési Szabályzata 25/2018. (EÉSZ) alapján. A Huba ajtó engedélyezési csomaggal."
>
  <Hero
    eyebrow="Budapest · VII. kerület"
    heading="Erzsébetváros — <em>két szabályozás egyszerre.</em>"
    lead="A VII. kerület Erzsébetváros a magyar főváros egyik legsűrűbb polgári bérházi szövete — a zsidónegyed és a belső Erzsébetváros. Itt két párhuzamos szabályozás él: a 25/2017. (XII. 22.) településképi rendelet és az Erzsébetváros Építési Szabályzata (EÉSZ) 25/2018. Mindkettőt figyelembe kell venni."
    image="/assets/photos/hero/period-double-leaf.jpg"
    imageAlt="Erzsébetvárosi polgári kétszárnyú biztonsági ajtó kovácsoltvas filigrán panelokkal"
    imageCaption="Erzsébetváros · klasszikus polgári portfólió"
    primaryCta={{ label: "Felmérés foglalása", href: "/felmeres" }}
    secondaryCta={{ label: "Vissza az útmutatóhoz", href: "/orokségvedelmi-engedely" }}
  />

  <div id="below"></div>

  <Section
    tone="paper"
    eyebrow="A két szabályozás"
    heading="25/2017. + EÉSZ 25/2018. — egymás mellett."
  >
    <p class="lead-text reveal">
      Az Erzsébetváros településképi rendelete (25/2017.) a vizuális megjelenést szabályozza —
      homlokzati nyílászárók, vasalat, szín, anyaghasználat. Az Erzsébetváros Építési Szabályzata
      (25/2018.) ezen felül a klasszikus építési előírásokat is rögzíti: beépíthetőség,
      műemléki értékek megőrzése, az utcakép koherenciája.
    </p>
    <p class="body-text reveal">
      Egy ajtócsere a VII. kerületben mindkét szabályozás alatt lehet érintett — különösen az
      utcafronti és lépcsőházi nyílászáróknál. A párhuzamos hatóság az Erzsébetvárosi
      polgármester / főépítészi iroda.
    </p>
  </Section>

  <Section
    tone="cream"
    eyebrow="Erzsébetvárosi formanyelv"
    heading="A leggazdagabb formavilág a fővárosban."
  >
    <p class="body-text reveal">
      A zsidónegyed és a belső Erzsébetváros polgári lakásajtói a város egyik leggazdagabb
      formavilágát mutatják — gyakran 5-6 osztású üvegezett felülrésszel, alul kazettás kivitellel,
      kovácsolt geometrikus rácsozással. Az építész partnerünk és a műemléki szakértő közreműködésével
      minden egyes ajtó egyedi értékleltár-kivonattal készíthető elő.
    </p>
    <ul class="bullet-list">
      <li><strong>Üvegezett felső szakasz:</strong> jellemzően 5-6 osztású ólmozott vagy
        homokfúvott üveg, geometrikus mintával.</li>
      <li><strong>Kazettás alsó szakasz:</strong> 2-3 vízszintes kazettával vagy 4 függőleges
        betéttel.</li>
      <li><strong>Kovácsoltvas rácsozás:</strong> geometrikus, klasszikus szecessziós motívumokkal
        is gyakran.</li>
      <li><strong>Szín:</strong> sok bérházban sötétzöld, gesztenyebarna, vagy sötétkék az eredeti.</li>
      <li><strong>Vasalat:</strong> sárgaréz vagy bronz, gyakran ovális rozetta-formákkal.</li>
    </ul>
  </Section>

  <Section
    tone="paper"
    eyebrow="A folyamat"
    heading="VII. kerületi engedélyezés — két irányból."
  >
    <ol class="process-list">
      <li><strong>Védettségi ellenőrzés</strong> — OÉNY + Erzsébetvárosi főépítészi konzultáció.</li>
      <li><strong>Helyszíni felmérés</strong> — méretes rajz, profilozás, üvegminta, vasalat.</li>
      <li><strong>Tervdokumentáció + építéstörténeti értékleltár</strong> — szakértői névjegyzéki
        szakértővel.</li>
      <li><strong>Településképi bejelentés</strong> a kerületi polgármesterhez — 15 nap.</li>
      <li><strong>Örökségvédelmi engedély</strong> ha nevesített elem — +25 nap.</li>
      <li><strong>Gyártás és beépítés</strong> — engedélyezett kivitelben.</li>
      <li><strong>Befejezési bejelentés.</strong></li>
    </ol>
    <p class="footnote reveal">
      Átlagos folyamat: 4-5 hónap.
    </p>
  </Section>

  <Section
    tone="cream"
    eyebrow="A Huba ajtó VII. kerületben"
    heading="A leggazdagabb portfóliónk."
  >
    <p class="body-text reveal">
      Az erzsébetvárosi munkáink a Huba ajtó archívumának egyik leggazdagabb csoportja —
      gyakran többszörös kazettás-ólmozott üveg kombináció, kovácsoltvas geometrikus rácsozással.
      A látható réteg minden esetben az eredeti ajtó alapján rekonstruált fa-felület, belül
      acélbetétes biztonsági szerkezettel.
    </p>
    <p class="body-text reveal">
      <a href="/muemleki-biztonsagi-ajto">Műemléki biztonsági ajtó — termékoldal →</a> ·
      <a href="/referenciak">Referenciagaléria →</a>
    </p>
  </Section>

  <ContactCTA
    heading="VII. kerületi címre felmérés"
    lead={`Kistarcsáról ${SLA.surveyDays} alatt érünk Erzsébetvárosba is.`}
  />
</BaseLayout>

<style>
  .lead-text { font-family: var(--font-serif); font-size: 1.2rem; line-height: 1.6; color: var(--color-charcoal); max-width: 60ch; }
  .body-text { font-size: 1rem; line-height: 1.7; color: var(--color-charcoal); max-width: 64ch; margin-top: 1rem; }
  .body-text a { color: var(--color-brass-deep); text-decoration: underline; text-underline-offset: 3px; }

  .bullet-list, .process-list {
    padding: 0; max-width: 64ch; display: flex; flex-direction: column; gap: 0.85rem;
    font-size: 1rem; line-height: 1.6; color: var(--color-charcoal);
  }
  .bullet-list { list-style: none; }
  .bullet-list li { padding-left: 1.25rem; position: relative; }
  .bullet-list li::before { content: ""; position: absolute; left: 0; top: 0.7em; width: 0.55rem; height: 1px; background: var(--color-brass); }
  .bullet-list strong { color: var(--color-ink); }
  .process-list { list-style: decimal; padding-left: 1.5rem; }
  .process-list strong { color: var(--color-ink); }

  .footnote { margin-top: 1.5rem; font-size: 0.95rem; color: var(--color-stone); max-width: 64ch; }
  .footnote strong { color: var(--color-ink); }
</style>
