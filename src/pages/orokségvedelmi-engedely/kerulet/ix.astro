---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import Section from "../../../components/Section.astro";
import ContactCTA from "../../../components/ContactCTA.astro";
import { SLA } from "../../../data/site";
---

<BaseLayout
  title="Ferencváros (IX.) — örökségvédelmi engedély ajtócseréhez"
  description="A IX. kerület Ferencváros ajtócseréinek szabályozása a 8/2024. (IV. 24.) önkormányzati rendelet alapján. Ráday utcai és Ferenc körúti polgári bérházak, udvari és lépcsőházi nyílászárók — a Huba ajtó engedélyezési csomaggal."
>
  <Hero
    eyebrow="Budapest · IX. kerület"
    heading="Ferencváros — <em>új, 2024-es szabályozás.</em>"
    lead="A IX. kerület Ferencváros 2024 áprilisában frissített településképvédelmi szabályozást vezetett be a 8/2024. (IV. 24.) önkormányzati rendelettel. A Ráday utcai és Ferenc körúti polgári bérházak utcai és udvari nyílászáróira, valamint a lépcsőházi lakásajtókra szigorúbb településképi bejelentési kötelezettség vonatkozik."
    image="/assets/photos/hero/period-yellow.jpg"
    imageAlt="Ferencvárosi polgári biztonsági ajtó kovácsoltvas filigrán rácsbetétekkel"
    imageCaption="Ferencváros · polgári bérház"
    primaryCta={{ label: "Felmérés foglalása", href: "/felmeres" }}
    secondaryCta={{ label: "Vissza az útmutatóhoz", href: "/orokségvedelmi-engedely" }}
  />

  <div id="below"></div>

  <Section
    tone="paper"
    eyebrow="Az új rendelet"
    heading="8/2024. (IV. 24.) — frissített szabályozás."
  >
    <p class="lead-text reveal">
      A Ferencváros 8/2024. (IV. 24.) önkormányzati rendelete a Ráday utcai és Ferenc körúti
      polgári bérházállomány védelmét célzottan erősíti. A rendelet kitér az utcai és udvari
      homlokzati nyílászárókra, valamint — más kerületi gyakorlathoz hasonlóan — a lépcsőházi
      lakásajtókra is.
    </p>
    <p class="body-text reveal">
      Az új szabályozás indoka egyértelmű: a Ráday utca és környéke az elmúlt évtizedek
      közterületi-gasztronómiai megújulása mellett az eredeti polgári építészeti karaktert
      tovább érdemes őrizni. A homlokzati nyílászárók aránya és anyaga ennek a karakternek a
      gerince.
    </p>
  </Section>

  <Section
    tone="cream"
    eyebrow="Tipikus IX. kerületi ajtó"
    heading="Udvari és lépcsőházi nyílászárók."
  >
    <p class="body-text reveal">
      A IX. kerületi munkáink jellegzetes esetei:
    </p>
    <ul class="bullet-list">
      <li><strong>Utcafronti kétszárnyú kapuk:</strong> jellemzően transzom üvegezett felső
        szakasszal, kovácsolt filigrán rácsbetétekkel.</li>
      <li><strong>Udvari homlokzati lakásajtók:</strong> sok esetben ezek is bejelentéskötelesek,
        mert láthatók a közös udvarról.</li>
      <li><strong>Lépcsőházi lakásajtók:</strong> 6-osztású ólmozott üveg felsőrésszel, alul
        kazettás vagy betétes kivitellel.</li>
      <li><strong>Anyag:</strong> fa, alumínium vagy műanyag általában nem.</li>
      <li><strong>Szín:</strong> a kerületi gyakorlat szerint az eredeti palettához idomulva.</li>
    </ul>
  </Section>

  <Section
    tone="paper"
    eyebrow="A folyamat"
    heading="IX. kerületi engedélyezés."
  >
    <ol class="process-list">
      <li><strong>Védettségi ellenőrzés</strong> — OÉNY + Ferencvárosi főépítészi konzultáció.</li>
      <li><strong>Helyszíni felmérés</strong> — eredeti ajtó dokumentálása, profilrajz, üveg.</li>
      <li><strong>Tervdokumentáció</strong> — építész tervezővel.</li>
      <li><strong>Településképi bejelentés</strong> — 15 napos eljárás a 8/2024. szerint.</li>
      <li><strong>Örökségvédelmi engedély</strong> ha nevesített elem — +25 nap.</li>
      <li><strong>Gyártás és beépítés.</strong></li>
      <li><strong>Befejezési bejelentés.</strong></li>
    </ol>
    <p class="footnote reveal">
      Átlagos folyamat: 4-5 hónap.
    </p>
  </Section>

  <Section
    tone="cream"
    eyebrow="A Huba ajtó IX. kerületben"
    heading="Korhű kivitel a Ráday utcai sávban."
  >
    <p class="body-text reveal">
      A ferencvárosi munkáink többsége a Ráday utca, a Mester utca és a Lónyay utca polgári
      bérházállományán dolgozik. Korhű kazettás vagy betétes kivitel, festett vagy lazúrozott
      felülettel, kovácsoltvas / sárgaréz vasalattal — belül acélbetétes biztonsági szerkezettel.
    </p>
    <p class="body-text reveal">
      <a href="/muemleki-biztonsagi-ajto">Műemléki biztonsági ajtó — termékoldal →</a>
    </p>
  </Section>

  <ContactCTA
    heading="IX. kerületi címre felmérés"
    lead={`Kistarcsáról ${SLA.surveyDays} alatt érünk Ferencvárosba is.`}
  />
</BaseLayout>

<style>
  .lead-text { font-family: var(--font-serif); font-size: 1.2rem; line-height: 1.6; color: var(--color-charcoal); max-width: 60ch; }
  .body-text { font-size: 1rem; line-height: 1.7; color: var(--color-charcoal); max-width: 64ch; margin-top: 1rem; }
  .body-text a { color: var(--color-brass-deep); text-decoration: underline; text-underline-offset: 3px; }

  .bullet-list, .process-list {
    padding: 0; max-width: 64ch; display: flex; flex-direction: column; gap: 0.85rem;
    font-size: 1rem; line-height: 1.6; color: var(--color-charcoal);
  }
  .bullet-list { list-style: none; }
  .bullet-list li { padding-left: 1.25rem; position: relative; }
  .bullet-list li::before { content: ""; position: absolute; left: 0; top: 0.7em; width: 0.55rem; height: 1px; background: var(--color-brass); }
  .bullet-list strong { color: var(--color-ink); }
  .process-list { list-style: decimal; padding-left: 1.5rem; }
  .process-list strong { color: var(--color-ink); }

  .footnote { margin-top: 1.5rem; font-size: 0.95rem; color: var(--color-stone); max-width: 64ch; }
  .footnote strong { color: var(--color-ink); }
</style>
