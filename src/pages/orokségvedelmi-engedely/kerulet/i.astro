---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import Section from "../../../components/Section.astro";
import ContactCTA from "../../../components/ContactCTA.astro";
import { SLA } from "../../../data/site";
---

<BaseLayout
  title="Budavári lakásajtó cseréje — örökségvédelmi engedély (I. kerület)"
  description="A Budavári Várnegyed (I. kerület) ajtócseréinek szabályozása — Budavári 30/2022. (XII. 20.) önkormányzati rendelet, UNESCO világörökségi terület. Mit lehet, mit nem, hogyan szerez engedélyt a Huba ajtóval együtt."
>
  <Hero
    eyebrow="Budapest · I. kerület"
    heading="Budavári lakásajtó — <em>UNESCO világörökség.</em>"
    lead="A budai Várnegyed Magyarország egyetlen olyan kerülete, ahol a kerületi településképvédelmi rendelet külön kiemeli a világörökségi szigorúságot. A 30/2022. (XII. 20.) önkormányzati rendelet a 2022 végén bevezetett, jelenleg érvényes szabályozás."
    image="/assets/photos/hero/period-yellow.jpg"
    imageAlt="Budavári polgári lakás bejárati ajtaja, korhű sárga festéssel, kovácsoltvas filigrán rácsbetétekkel"
    imageCaption="Budavári Várnegyed · 2024"
    primaryCta={{ label: "Felmérés foglalása", href: "/felmeres" }}
    secondaryCta={{ label: "Vissza az útmutatóhoz", href: "/orokségvedelmi-engedely" }}
  />

  <div id="below"></div>

  <Section
    tone="paper"
    eyebrow="A kerületi rendelet"
    heading="Budavári 30/2022. (XII. 20.) — szó szerint."
  >
    <p class="lead-text reveal">
      A budai Várnegyed UNESCO világörökségi területén az ajtócsere különleges szabályok alá esik. A
      30/2022. (XII. 20.) önkormányzati rendelet a következőképpen fogalmaz:
    </p>
    <blockquote class="quote reveal">
      „Világörökség részét képező területen, 1945 előtt épült épület utcai homlokzatainak nyílászáró
      felújításakor csak az eredeti nyílászáróval megegyező ablak helyezhető el, és külső megjelenése sem
      térhet el az eredetitől."
      <cite>— Budavári Önkormányzat 30/2022. (XII. 20.) rendelete a településkép védelméről</cite>
    </blockquote>
    <p class="body-text reveal">
      Ez a rendelkezés a magyarországi településképvédelem legszigorúbb gyakorlati előírása. A Budavári
      önkormányzat főépítészi irodája — a Budapest Főváros Kormányhivatala Építésügyi és Örökségvédelmi
      Főosztályával együttműködve — ezt az alapelvet konzekvensen érvényesíti.
    </p>
  </Section>

  <Section
    tone="cream"
    eyebrow="Mit jelent ez konkrétan?"
    heading="Az új ajtónak meg kell egyeznie az eredetivel."
  >
    <ul class="bullet-list">
      <li>
        <strong>Anyag:</strong> fa — tölgy vagy vörösfenyő. Műanyag, alumínium közterületről látható
        homlokzaton nem építhető be.
      </li>
      <li>
        <strong>Beépítési sík:</strong> az eredeti pozícióban — nem előrébb és nem hátrébb.
      </li>
      <li>
        <strong>Osztásrend:</strong> az eredeti üveg-, kazetta- és betétarány megőrzése. Ha az eredeti
        felső 1/3-ban két, középen három, alul betétes volt, az új is ugyanaz.
      </li>
      <li>
        <strong>Szín:</strong> az értékleltár szerinti eredeti szín — jellemzően RAL 6009 sötétzöld, RAL
        8014 gesztenyebarna, RAL 5008 sötétkék. Fehér csak akkor, ha az eredeti is fehér volt.
      </li>
      <li>
        <strong>Vasalat:</strong> kovácsoltvas, sárgaréz — modern fényes króm nem.
      </li>
      <li>
        <strong>Üvegezés:</strong> ha az eredeti ólmozott vagy metszett volt, az új is olyan.
      </li>
    </ul>
  </Section>

  <Section
    tone="paper"
    eyebrow="A Huba ajtó megoldása"
    heading="A látható réteg korhű — belül acél."
  >
    <p class="body-text reveal">
      A Budavári rendelet a megjelenést szabályozza, nem a belső szerkezetet. A Huba ajtó pontosan ebben a
      hézagban tudja a vevőnek mindkét célt egyszerre kiszolgálni: az utcai homlokzaton megjelenő réteg
      tölgyfa kazettás vagy betétes, korhű festéssel és kovácsoltvas veretekkel — a hatóság elfogadja. A
      belső réteg viszont acélbetétes biztonsági szerkezet, MABISZ-minősített, prémium zárral.
    </p>
    <p class="body-text reveal">
      A budai Várnegyedben dolgozó kollégáink a felmérés első napjától M=1:10 méretarányos rajzzal,
      anyagmintatáblával és az eredeti ajtó alapos fotódokumentálásával készítik elő az engedélyezési
      anyagot. A védettségi ellenőrzést az OÉNY rendszeren keresztül és a budavári főépítészi irodával is
      tisztázzuk.
    </p>
  </Section>

  <Section
    tone="cream"
    eyebrow="Eljárás és határidő"
    heading="Mi a teendő, ha Budavári lakásajtót cserélne?"
  >
    <ol class="process-list">
      <li>
        <strong>Védettségi ellenőrzés</strong> — OÉNY helyrajzi szám alapján + a budavári főépítészi
        irodával történő konzultáció. Mi végezzük.
      </li>
      <li>
        <strong>Helyszíni felmérés</strong> — méretek, profilozás, eredeti vasalat, üveg, szín.
        Mintamintával érkezünk.
      </li>
      <li>
        <strong>Tervdokumentáció + építéstörténeti értékleltár</strong> — partner építésszel és műemléki
        szakértői névjegyzéki szakértővel.
      </li>
      <li>
        <strong>Engedélyezés ÉTDR-en keresztül</strong> — 25 napos ügyintézés a Budapest Főváros
        Kormányhivatalánál + 15 napos kerületi településképi bejelentés.
      </li>
      <li>
        <strong>Gyártás és beépítés</strong> — a kistarcsai műhelyben, az engedélyben előírt kikötések
        szerint.
      </li>
      <li>
        <strong>Befejezési bejelentés</strong> — a hatósági szemle koordinálásával.
      </li>
    </ol>
    <p class="footnote reveal">
      Teljes folyamat: <strong>{SLA.permitTotal}</strong>. A Budavári esetekben az átlag 5-6 hónap, mert a
      világörökségi terület esetében a hatóság alaposabban dokumentál.
    </p>
  </Section>

  <ContactCTA
    heading="Budavári címre felmérés"
    lead="A budai oldalra Kistarcsáról 45 perc — felmérőnk az első órán a védettségi és OÉNY ellenőrzést elvégzi."
  />
</BaseLayout>

<style>
  .lead-text {
    font-family: var(--font-serif); font-size: 1.2rem; line-height: 1.6;
    color: var(--color-charcoal); max-width: 60ch;
  }
  .body-text {
    font-size: 1rem; line-height: 1.7; color: var(--color-charcoal); max-width: 64ch;
    margin-top: 1rem;
  }
  .quote {
    margin: 2rem 0; padding: 1.5rem 1.5rem 1.5rem 2rem;
    border-left: 3px solid var(--color-brass);
    font-family: var(--font-serif); font-size: 1.15rem; line-height: 1.55;
    color: var(--color-ink); font-style: italic;
    max-width: 64ch;
  }
  .quote cite {
    display: block; margin-top: 1rem;
    font-style: normal; font-size: 0.8rem; color: var(--color-stone);
    font-family: var(--font-sans); letter-spacing: var(--tracking-wide); text-transform: uppercase;
  }

  .bullet-list, .process-list {
    padding: 0; max-width: 64ch;
    display: flex; flex-direction: column; gap: 0.85rem;
    font-size: 1rem; line-height: 1.6; color: var(--color-charcoal);
  }
  .bullet-list { list-style: none; }
  .bullet-list li {
    padding-left: 1.25rem; position: relative;
  }
  .bullet-list li::before {
    content: ""; position: absolute; left: 0; top: 0.7em;
    width: 0.55rem; height: 1px; background: var(--color-brass);
  }
  .bullet-list strong { color: var(--color-ink); }
  .process-list { list-style: decimal; padding-left: 1.5rem; }
  .process-list strong { color: var(--color-ink); }

  .footnote {
    margin-top: 1.5rem; font-size: 0.95rem; color: var(--color-stone);
    max-width: 64ch;
  }
  .footnote strong { color: var(--color-ink); }
</style>
