---
interface Props {
  value: string;
  label: string;
  sub?: string;
}
const { value, label, sub } = Astro.props;
---
<div class="stat reveal">
  <p class="stat-value">{value}</p>
  <p class="stat-label">{label}</p>
  {sub && <p class="stat-sub">{sub}</p>}
</div>

<style>
  .stat { display: flex; flex-direction: column; gap: 0.4rem; }
  .stat-value { font-family: var(--font-serif); font-size: clamp(3rem, 6vw, 4.8rem); line-height: 0.95; letter-spacing: -0.02em; color: var(--color-ink); }
  .stat-label { font-family: var(--font-serif); font-size: 1.1rem; line-height: 1.3; color: var(--color-charcoal); }
  .stat-sub { font-size: 0.78rem; letter-spacing: 0.04em; color: var(--color-stone); }
</style>
