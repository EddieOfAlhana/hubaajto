---
import LogoMark from "./LogoMark.astro";
import { SITE, CONTACT, FOOTER_NAV } from "../data/site";
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="site-footer-top">
      <div class="site-footer-brand">
        <LogoMark variant="wordmark" size="md" />
        <p class="site-footer-tag">{SITE.taglineLong}</p>

        <address class="site-footer-address">
          <strong>{SITE.legalName}</strong><br/>
          {CONTACT.address.postal} {CONTACT.address.city}, {CONTACT.address.street}<br/>
          <a href={`tel:${CONTACT.phonePrimaryTel.replace(/\s/g, "")}`}>{CONTACT.phonePrimary}</a><br/>
          <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
        </address>

        <div class="site-footer-hours">
          <span>{CONTACT.hours.weekday}</span>
          <span>{CONTACT.hours.saturday}</span>
        </div>
      </div>

      <nav class="site-footer-nav">
        {FOOTER_NAV.map(group => (
          <div class="site-footer-group">
            <h4 class="site-footer-heading">{group.heading}</h4>
            <ul>
              {group.links.map(link => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </div>

    <div class="site-footer-bottom">
      <div class="site-footer-meta">
        <span class="tricolor-strip" aria-hidden="true"><span/><span/><span/></span>
        <span>© {year} {SITE.shortLegal}. Minden jog fenntartva.</span>
        <span class="site-footer-tag-small">MABISZ-minősített {SITE.mabiszSince} óta · Kistarcsán gyártva</span>
      </div>
      <button class="site-footer-cookies" data-cookie-reopen>Süti beállítások</button>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink); color: var(--color-mist);
    padding-block: clamp(3rem, 6vw, 5.5rem) 2rem;
    margin-top: clamp(4rem, 10vw, 7rem);
  }
  .site-footer h4, .site-footer strong, .site-footer a:hover { color: var(--color-paper); }
  .site-footer a { transition: color var(--dur-fast) var(--ease-out-soft); }

  .site-footer-top {
    display: grid; grid-template-columns: 1fr; gap: 2.5rem;
    padding-bottom: 3rem; border-bottom: 1px solid rgba(247, 244, 238, 0.1);
  }
  @media (min-width: 900px) { .site-footer-top { grid-template-columns: 1.2fr 2fr; gap: 4rem; } }

  .site-footer-brand img { filter: invert(1) brightness(2); }
  .site-footer-tag {
    font-family: var(--font-serif); font-size: 1.05rem; line-height: 1.4;
    color: var(--color-paper); margin-top: 1rem; max-width: 28ch;
  }
  .site-footer-address { font-style: normal; font-size: 0.9rem; line-height: 1.7; margin-top: 1.5rem; color: var(--color-mist); }
  .site-footer-hours { display: flex; flex-direction: column; gap: 0.25rem; margin-top: 1rem; font-size: 0.85rem; color: var(--color-mist); }

  .site-footer-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  @media (min-width: 720px) { .site-footer-nav { grid-template-columns: 1fr 1fr 1fr 1fr; } }
  .site-footer-heading {
    font-family: var(--font-sans); font-size: 0.7rem; letter-spacing: var(--tracking-wide);
    text-transform: uppercase; color: var(--color-paper); margin-bottom: 1rem;
  }
  .site-footer-group ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .site-footer-group a { font-size: 0.9rem; color: var(--color-mist); }

  .site-footer-bottom {
    padding-top: 2rem; display: flex; flex-wrap: wrap; gap: 1.25rem;
    align-items: center; justify-content: space-between; font-size: 0.8rem;
  }
  .site-footer-meta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .site-footer-tag-small { color: var(--color-stone); font-size: 0.78rem; letter-spacing: 0.03em; }
  .site-footer-cookies {
    background: none; border: 1px solid rgba(247,244,238,0.2); color: var(--color-mist);
    padding: 0.5rem 0.9rem; font-size: 0.78rem; cursor: pointer; letter-spacing: 0.03em;
    transition: all var(--dur-fast) var(--ease-out-soft);
  }
  .site-footer-cookies:hover { background: var(--color-paper); color: var(--color-ink); }
</style>
