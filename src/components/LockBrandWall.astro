---
import { LOCKS } from "../data/site";
---
<div class="lock-wall reveal" aria-label="Premium European lock brands">
  <p class="lock-wall-label">Prémium európai zárakkal</p>
  <ul class="lock-wall-list stagger">
    {LOCKS.map(name => (
      <li class="lock-wall-name">{name}</li>
    ))}
  </ul>
</div>

<style>
  .lock-wall {
    display: flex; flex-direction: column; align-items: center; gap: 1.5rem;
    padding-block: 2rem;
  }
  .lock-wall-label {
    font-size: 0.72rem; letter-spacing: var(--tracking-wide); text-transform: uppercase;
    color: var(--color-stone);
  }
  .lock-wall-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; justify-content: center; align-items: center;
    gap: 2rem 3rem;
  }
  .lock-wall-name {
    font-family: var(--font-serif); font-size: clamp(1.4rem, 2vw, 1.8rem);
    color: var(--color-charcoal); letter-spacing: -0.01em;
    transition: color var(--dur) var(--ease-out-soft);
  }
  .lock-wall-name:hover { color: var(--color-ink); }
</style>
