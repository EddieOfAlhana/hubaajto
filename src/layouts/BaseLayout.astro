---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileStickyCTA from "../components/MobileStickyCTA.astro";
import { SITE, CONTACT } from "../data/site";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schema?: object | object[];
  canonical?: string;
  bodyClass?: string;
}

const { title, description, ogImage = "/assets/brand/og-default.png", schema, canonical, bodyClass = "" } = Astro.props;
const fullTitle = title.includes(SITE.brand) ? title : `${title} | ${SITE.brand}`;
const url = canonical ?? new URL(Astro.url.pathname, SITE.url).toString();

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "@id": `${SITE.url}/#org`,
  name: SITE.brand,
  legalName: SITE.legalName,
  url: SITE.url,
  telephone: CONTACT.phonePrimary,
  email: CONTACT.email,
  image: `${SITE.url}/assets/brand/og-default.png`,
  priceRange: "330000 - 2500000 HUF",
  foundingDate: String(SITE.founded),
  address: {
    "@type": "PostalAddress",
    streetAddress: CONTACT.address.street,
    addressLocality: CONTACT.address.city,
    postalCode: CONTACT.address.postal,
    addressCountry: "HU",
    addressRegion: "Pest",
  },
  geo: { "@type": "GeoCoordinates", latitude: CONTACT.address.latitude, longitude: CONTACT.address.longitude },
  areaServed: [
    { "@type": "AdministrativeArea", name: "Budapest" },
    { "@type": "AdministrativeArea", name: "Pest vármegye" },
  ],
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: "08:00", closes: "17:00" },
    { "@type": "OpeningHoursSpecification", dayOfWeek: "Saturday", opens: "08:00", closes: "12:00" },
  ],
};
const allSchema = schema ? [defaultSchema].concat(Array.isArray(schema) ? schema : [schema]) : [defaultSchema];
---
<!doctype html>
<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={new URL(ogImage, SITE.url).toString()} />
    <meta property="og:locale" content="hu_HU" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/png" href="/assets/brand/monogram.png" />
    <link rel="apple-touch-icon" href="/assets/brand/monogram.png" />

    <!-- Fonts: Cormorant Garamond (heritage serif) + Inter (UI sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;450;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;450;500;600&display=swap" />

    <script type="application/ld+json" set:html={JSON.stringify(allSchema)} />

    <ClientRouter />
  </head>
  <body class={bodyClass}>
    <a href="#main" class="skip-link">Tartalom kihagyása</a>
    <Header />
    <main id="main" transition:animate="fade">
      <slot />
    </main>
    <Footer />
    <MobileStickyCTA />

    <script>
      // GSAP reveal-on-scroll
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      gsap.registerPlugin(ScrollTrigger);

      const initReveals = () => {
        document.querySelectorAll<HTMLElement>(".reveal").forEach((el) => {
          gsap.to(el, {
            opacity: 1, y: 0, duration: 0.9, ease: "expo.out",
            scrollTrigger: { trigger: el, start: "top 88%", once: true },
          });
        });
        document.querySelectorAll<HTMLElement>(".stagger").forEach((el) => {
          gsap.to(el.children, {
            opacity: 1, y: 0, duration: 0.7, ease: "expo.out", stagger: 0.08,
            scrollTrigger: { trigger: el, start: "top 85%", once: true },
          });
        });
      };

      initReveals();
      document.addEventListener("astro:page-load", () => { ScrollTrigger.refresh(); initReveals(); });
    </script>

    <style is:global>
      .skip-link {
        position: absolute; left: -9999px; top: 0; padding: 0.75rem 1rem;
        background: var(--color-ink); color: var(--color-paper); z-index: 100;
      }
      .skip-link:focus { left: 1rem; top: 1rem; }
    </style>
  </body>
</html>
